# ASCIIVision API Keys
# Copy this file to .env and fill in the keys you want to use.
# Only the providers you want are required -- everything else works without keys.

# Claude API (https://console.anthropic.com/)
CLAUDE_API_KEY=

# Grok API (https://x.ai/)
GROK_API_KEY=

# OpenAI API (https://platform.openai.com/)
OPENAI_API_KEY=

# Gemini API (https://ai.google.dev/)
GEMINI_API_KEY=
